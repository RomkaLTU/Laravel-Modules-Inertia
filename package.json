{
    "name": "laravel-modules-inertia",
    "version": "0.2.1",
    "description": "Vite plugin and page resolver for nwidart/laravel-modules + Inertia.js",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./vite": {
            "types": "./dist/vite-plugin.d.ts",
            "import": "./dist/vite-plugin.js"
        },
        "./resolve-page": {
            "types": "./dist/resolve-page.d.ts",
            "import": "./dist/resolve-page.js"
        }
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run"
    },
    "peerDependencies": {
        "@inertiajs/react": "^2.0.0 || ^3.0.0",
        "laravel-vite-plugin": "^1.0.0 || ^2.0.0 || ^3.0.0",
        "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
    },
    "devDependencies": {
        "@inertiajs/react": "^3.0.0",
        "@types/node": "^25.5.2",
        "jsonc-parser": "^3.3.1",
        "laravel-vite-plugin": "^1.0.0",
        "tsup": "^8.0.0",
        "typescript": "^5.5.0",
        "vite": "^6.0.0",
        "vitest": "^4.1.2"
    }
}
