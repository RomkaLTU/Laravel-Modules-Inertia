{
    "name": "romkaltu/laravel-modules-inertia",
    "description": "Inertia.js page resolution for nwidart/laravel-modules",
    "keywords": ["laravel", "inertia", "modules", "nwidart"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/view": "^11.0|^12.0|^13.0",
        "inertiajs/inertia-laravel": "^2.0|^3.0",
        "nwidart/laravel-modules": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "RomkaLTU\\InertiaModules\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RomkaLTU\\InertiaModules\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RomkaLTU\\InertiaModules\\InertiaModulesServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "laravel/pint": "^1.29",
        "phpstan/phpstan": "^2.1",
        "pestphp/pest": "*",
        "orchestra/testbench": "*"
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse",
        "format": "pint",
        "format:test": "pint --test",
        "check": [
            "@test",
            "@analyse",
            "@format:test"
        ]
    },
    "config": {
        "allow-plugins": {
            "wikimedia/composer-merge-plugin": true,
            "pestphp/pest-plugin": true
        }
    }
}
